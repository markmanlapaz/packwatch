# PackWatch watcher environment.
# Copy to .env for local dev. In CI these come from GitHub repo secrets.

# Discord incoming webhook — the target channel for restock pings.
DISCORD_WEBHOOK_URL=

# Resend API key (https://resend.com) — transactional email sender.
RESEND_API_KEY=

# Inbox that receives restock emails. Usually your own.
NOTIFY_EMAIL=

# Verified sender on your Resend domain. Must be a domain you own + verified in Resend.
RESEND_FROM_EMAIL=

# Optional — logger verbosity: debug | info | warn | error. Defaults to "info".
LOG_LEVEL=info

# Optional — "true" skips notifications AND state writes. Use for local dry-runs.
DRY_RUN=false
